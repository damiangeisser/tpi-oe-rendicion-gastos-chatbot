<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_0o87biy" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="204af60" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0" camunda:diagramRelationId="fb106f6d-8291-4045-83fc-3ca3615685f3">
  <bpmn:collaboration id="RendicionGastosInternosToBe" name="Rendicion Gastos Internos As Is">
    <bpmn:documentation>Disparado por un empleado que requiere la devolución de un gasto generado por su actividad laboral. El camino feliz es que el chatbot valide la solicitud, registre la rendición, apruebe el reintegro automáticamente y notifique la decisión al empleado.</bpmn:documentation>
    <bpmn:participant id="Participant_056nh3b" name="Rendición de gastos internos mediante chatbot" processRef="Process_yvwxgi5">
      <bpmn:documentation>Proceso optimizado de rendición de gastos internos implementado mediante un chatbot de Telegram, con validaciones automáticas, persistencia en SQLite y derivación a supervisor cuando el monto supera el límite de aprobación automática.</bpmn:documentation>
    </bpmn:participant>
    <bpmn:textAnnotation id="TextAnnotation_rendicion_intro">
      <bpmn:extensionElements />
      <bpmn:text>Disparado por un empleado que requiere la devolución de un gasto generado por su actividad laboral. El camino feliz es que el chatbot valide la solicitud, registre la rendición, apruebe el reintegro automáticamente y notifique la decisión al empleado.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_rendicion_intro" associationDirection="None" sourceRef="EventoInicioReintegroGastoRequerido" targetRef="TextAnnotation_rendicion_intro" />
  </bpmn:collaboration>
  <bpmn:process id="Process_yvwxgi5" name="Rendición de gastos internos mediante chatbot" isExecutable="true">
    <bpmn:extensionElements />
    <bpmn:laneSet id="LaneSet_08mslvx">
      <bpmn:lane id="Empleado_Solicitante" name="Empleado solicitante">
        <bpmn:documentation>Rol que inicia el proceso de rendición mediante Telegram. Es responsable de ingresar los datos solicitados por el chatbot, seleccionar la categoría del gasto, informar el monto, enviar el comprobante y tomar conocimiento de la decisión comunicada por el sistema.</bpmn:documentation>
        <bpmn:flowNodeRef>EventoInicioReintegroGastoRequerido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaIniciarSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaIngresarLegajo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaSeleccionarCategoria</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaIngresarFecha</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteIngresarFecha</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaIngresarMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteIngresarMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaEnviarComprobante</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteEnviarComprobante</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Sistema_Chatbot" name="Sistema / Chatbot">
        <bpmn:documentation>Componente automatizado que guía al empleado durante la carga de la rendición, valida los datos ingresados, consulta la base de datos SQLite, aplica reglas de negocio, registra la solicitud y comunica la decisión final.</bpmn:documentation>
        <bpmn:flowNodeRef>CompuertaFechaValida</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaSolicitarCorreccionFecha</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaIncrementarIntentosFecha</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaSolicitarMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaValidarFormatoMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaIncrementarIntentosMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EventoFinSolicitudResuelta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaNotificarDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRegistrarComprobanteEnviado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaComprobanteValido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaSolicitarCorreccionComprobante</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaIncrementarIntentosComprobante</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaSolicitarComprobante</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRegistrarMontoIngresado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaMontoValido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteCancelarSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaCancelarSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaNotificarCancelacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EventoFinSolicitudCancelada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaIntentosComprobanteDisponibles</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaValidarComprobante</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaSolicitarCorreccionMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaIntentosMontoDisponibles</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaValidarFormatoFecha</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaSolicitarFecha</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRegistrarCategoriaSeleccionada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaMostrarCategoriasDisponibles</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRegistrarLegajoIngresado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaEmpleadoValidoActivo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaValidarEmpleado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaSolicitarLegajo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaVerificarLimiteAprobacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaMontoDentroLimite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaAprobarSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteGestionarReintegro</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaGestionarReintegro</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteRegistrarResultado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRegistrarResultado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaDerivarSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaInformarDerivacionSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRegistrarAutorizacionExcepcion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRegistrarRechazoExcepcion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaIntentosFechaDisponibles</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaConsultarPoliticaGastos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaVerificarCategoriaArea</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaCategoriaPermitida</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Supervisor" name="Supervisor">
        <bpmn:documentation>Rol responsable de revisar las rendiciones cuyo monto supera el límite de aprobación automática. Evalúa si la excepción está justificada y comunica su decisión al sistema para continuar con la aprobación, rechazo, registro y notificación correspondiente.</bpmn:documentation>
        <bpmn:flowNodeRef>CompuertaLimiteJustificado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaAutorizarExcepcionMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRechazarMontoSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRevisarSolicitudDerivada</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="EventoInicioReintegroGastoRequerido" name="Reintegro de gasto requerido">
      <bpmn:documentation>El proceso inicia cuando un empleado requiere recuperar el dinero correspondiente a un gasto realizado por su actividad laboral.</bpmn:documentation>
      <bpmn:outgoing>Flow_0zz28gx</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="TareaIniciarSolicitud" name="Iniciar solicitud">
      <bpmn:documentation>El empleado inicia la interacción con el chatbot de Telegram para comenzar una nueva solicitud de reintegro de gastos.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition externalReference="Form_08kwcf5" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0zz28gx</bpmn:incoming>
      <bpmn:outgoing>Flow_1qnrm7v</bpmn:outgoing>
    </bpmn:userTask>
