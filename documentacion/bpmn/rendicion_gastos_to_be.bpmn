      <bpmn:documentation>El supervisor rechaza el monto excepcional de la solicitud porque la superación del límite no está justificada.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition externalReference="Form_0f82064" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_15kjq3b</bpmn:incoming>
      <bpmn:outgoing>Flow_0w9p78b</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="TareaRevisarSolicitudDerivada" name="Revisar solicitud derivada">
      <bpmn:documentation>El supervisor revisa la solicitud derivada por el sistema debido a que el monto informado supera el límite de aprobación automática.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition externalReference="Form_0f82064" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0swkptc</bpmn:incoming>
      <bpmn:outgoing>Flow_0etjjpu</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0etjjpu" sourceRef="TareaRevisarSolicitudDerivada" targetRef="CompuertaLimiteJustificado" />
    <bpmn:sequenceFlow id="Flow_1p4q0sz" name="Sí" sourceRef="CompuertaLimiteJustificado" targetRef="TareaAutorizarExcepcionMonto">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=limiteJustificado = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_15kjq3b" name="No" sourceRef="CompuertaLimiteJustificado" targetRef="TareaRechazarMontoSolicitud">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=limiteJustificado = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sendTask id="TareaInformarDerivacionSolicitud" name="Informar la derivación de la solicitud">
      <bpmn:documentation>El chatbot informa al empleado que la solicitud fue derivada a revisión porque el monto supera el límite de aprobación automática.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="telegram-bot-message" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1c1whwu</bpmn:incoming>
      <bpmn:outgoing>Flow_0swkptc</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="TareaRegistrarAutorizacionExcepcion" name="Registrar autorización de excepción">
      <bpmn:documentation>El sistema registra la autorización realizada por el supervisor sobre una solicitud cuyo monto supera el límite de aprobación automática. A partir de esta decisión, la solicitud continúa como aprobada y puede avanzar hacia el registro del resultado y la notificación al empleado.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="registrar-autorizacion-excepcion" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0s0jkhk</bpmn:incoming>
      <bpmn:outgoing>Flow_0u83gdv</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="TareaRegistrarRechazoExcepcion" name="Registrar rechazo de excepción">
      <bpmn:documentation>El sistema registra el rechazo realizado por el supervisor sobre una solicitud cuyo monto supera el límite de aprobación automática. A partir de esta decisión, la solicitud continúa como rechazada y puede avanzar hacia el registro del resultado y la notificación al empleado.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="registrar-rechazo-excepcion" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0w9p78b</bpmn:incoming>
      <bpmn:outgoing>Flow_1ma5fws</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="CompuertaIntentosFechaDisponibles" name="¿Intentos de fecha disponibles?">
      <bpmn:documentation>Evalúa si el empleado aún dispone de intentos para corregir la fecha ingresada antes de cancelar la solicitud.</bpmn:documentation>
      <bpmn:incoming>Flow_0xb4t3q</bpmn:incoming>
      <bpmn:outgoing>Flow_0hlz7ca</bpmn:outgoing>
      <bpmn:outgoing>Flow_1rhutmm</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1rn5sba" sourceRef="TareaRegistrarCategoriaSeleccionada" targetRef="TareaSolicitarFecha" />
    <bpmn:serviceTask id="TareaConsultarPoliticaGastos" name="Consultar política de gastos">
      <bpmn:documentation>El sistema consulta la política de gastos vigente según el área del usuario y la categoría seleccionada. Si no existe una política activa para esa combinación, la solicitud se cancela. Si la combinación está permitida, el sistema compara el monto informado contra el límite de aprobación automática definido para esa política.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="consultar-politica-gastos" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1hvqlva</bpmn:incoming>
      <bpmn:outgoing>Flow_09ijfd8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1tyh0pj" sourceRef="TareaVerificarCategoriaArea" targetRef="CompuertaCategoriaPermitida" />
    <bpmn:businessRuleTask id="TareaVerificarCategoriaArea" name="Verificar categoría y área">
      <bpmn:documentation>El sistema busca las categorías de gasto permitidas para el área a la que pertenece el usuario.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="verificar-limite-aprobacion" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_09ijfd8</bpmn:incoming>
      <bpmn:outgoing>Flow_1tyh0pj</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="CompuertaCategoriaPermitida" name="¿Categoría permitida?">
      <bpmn:documentation>Determina si el gasto pertenece a una categóría permitida.</bpmn:documentation>
      <bpmn:incoming>Flow_1tyh0pj</bpmn:incoming>
      <bpmn:outgoing>Flow_04p4oma</bpmn:outgoing>
      <bpmn:outgoing>Flow_1cykgra</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_04p4oma" name="Sí" sourceRef="CompuertaCategoriaPermitida" targetRef="TareaVerificarLimiteAprobacion">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=categoriaPermitida = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1cykgra" name="No" sourceRef="CompuertaCategoriaPermitida" targetRef="TareaCancelarSolicitud">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=categoriaPermitida = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
