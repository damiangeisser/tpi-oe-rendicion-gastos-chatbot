    <bpmn:sequenceFlow id="Flow_1bjhrpm" name="Sí" sourceRef="CompuertaIntentosComprobanteDisponibles" targetRef="TareaSolicitarCorreccionComprobante">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=intentosComprobanteDisponibles = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
