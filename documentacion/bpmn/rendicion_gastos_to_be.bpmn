    </bpmn:sequenceFlow>
    <bpmn:userTask id="TareaIngresarLegajo" name="Ingresar legajo">
      <bpmn:documentation>El empleado ingresa su legajo en Telegram para identificarse ante el chatbot.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition externalReference="Form_0ckxbxu" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_05hw2sd</bpmn:incoming>
      <bpmn:outgoing>Flow_07yly08</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="TareaSeleccionarCategoria" name="Seleccionar categoría">
      <bpmn:documentation>El empleado selecciona desde el menú del chatbot la categoría correspondiente al gasto a rendir.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition externalReference="Form_0d95nuq" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0sa7c3t</bpmn:incoming>
      <bpmn:outgoing>Flow_1ui6wu9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="TareaIngresarFecha" name="Ingresar fecha">
      <bpmn:documentation>El empleado ingresa la fecha en la que fue realizado el gasto correspondiente a la rendición.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition externalReference="Form_0xbqvi2" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1j7xofo</bpmn:incoming>
      <bpmn:outgoing>Flow_1faw0ya</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="CompuertaFechaValida" name="¿Fecha válida?">
      <bpmn:documentation>Evalúa si la fecha ingresada por el empleado tiene un formato válido para continuar con la rendición.</bpmn:documentation>
      <bpmn:incoming>Flow_014olzz</bpmn:incoming>
      <bpmn:outgoing>Flow_0f200y6</bpmn:outgoing>
      <bpmn:outgoing>Flow_0w50w2s</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="CompuertaConvergenteIngresarFecha">
      <bpmn:documentation>Unifica el flujo inicial de solicitud de fecha y el flujo de corrección antes de que el empleado ingrese nuevamente la fecha del gasto.</bpmn:documentation>
      <bpmn:incoming>Flow_1eqckj2</bpmn:incoming>
      <bpmn:incoming>Flow_0lzigb8</bpmn:incoming>
      <bpmn:outgoing>Flow_1j7xofo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="TareaSolicitarCorreccionFecha" name="Solicitar corrección de la fecha">
