<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_0o87biy" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="1d3193f" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0" camunda:diagramRelationId="fb106f6d-8291-4045-83fc-3ca3615685f3">
  <bpmn:collaboration id="RendicionGastosInternosAsIs" name="Rendicion Gastos Internos As Is">
    <bpmn:documentation>Proceso administrativo manual mediante el cual un empleado solicita el reintegro de un gasto realizado por su actividad laboral.</bpmn:documentation>
    <bpmn:participant id="Participant_056nh3b" name="Rendición manual de gastos internos" processRef="ProcesoRendicionManualGastosInternos" />
    <bpmn:textAnnotation id="TextAnnotation_rendicion_intro">
      <bpmn:extensionElements />
      <bpmn:text>Disparado por un empleado que requiere la devolución de un gasto generado por la actividad laboral. El camino feliz es la administración aprobando el gasto y reintegrándole el dinero.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_rendicion_intro" associationDirection="None" sourceRef="EventoInicioReintegroGastoRequerido" targetRef="TextAnnotation_rendicion_intro" />
  </bpmn:collaboration>
  <bpmn:process id="ProcesoRendicionManualGastosInternos" name="Rendicion Manual Gastos Internos" isExecutable="true">
    <bpmn:extensionElements />
    <bpmn:laneSet id="LaneSet_08mslvx">
      <bpmn:lane id="Supervisor" name="Supervisor">
        <bpmn:documentation>Rol responsable de revisar las rendiciones que superan el límite de aprobación directa. Evalúa si la excepción de monto está justificada y comunica su decisión al área administrativa para continuar con el registro y la notificación del resultado.</bpmn:documentation>
        <bpmn:flowNodeRef>CompuertaLimiteJustificado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRevisarSolicitudDerivada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaAutorizarExcepcionMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRechazarMontoSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaComunicarAutorizacionMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaComunicarRechazoMonto</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Area_Administrativa" name="Área administrativa">
        <bpmn:documentation>Sector responsable de recibir, revisar, validar, resolver y registrar las rendiciones de gastos presentadas por los empleados.</bpmn:documentation>
        <bpmn:flowNodeRef>CompuertaMontoDentroLimite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaCategoriaValida</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaDatosCompletos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaEmpleadoValidoActivo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRecibirRendicion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaSolicitarCorreccion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRevisarDatosObligatorios</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaValidarEmpleado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaValidarCategoria</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaVerificarLimiteAprobacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaAprobarSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaDerivarSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaConfirmarRecepcionAutorizacionMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaNotificarResultado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRechazarSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaRegistrarResultado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaConfirmarRecepcionRechazoMonto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteRegistrarResultado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaGestionarReintegro</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteGestionarReintegro</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteRechazoSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CompuertaConvergenteNotificarResultado</bpmn:flowNodeRef>
        <bpmn:childLaneSet id="LaneSet_1pi6k06" />
      </bpmn:lane>
      <bpmn:lane id="Empleado_Solicitante" name="Empleado solicitante">
        <bpmn:documentation>Rol que inicia el proceso de rendición al solicitar el reintegro de un gasto realizado por su actividad laboral. Es responsable de completar y enviar la rendición, y de tomar conocimiento de la decisión comunicada por el área administrativa.</bpmn:documentation>
        <bpmn:flowNodeRef>EventoInicioReintegroGastoRequerido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EventoFinSolicitudResuelta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaCompletarRendicion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaEnviarRendicion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>TareaConfirmarRecepcionDecision</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="EventoInicioReintegroGastoRequerido" name="Reintegro de gasto requerido">
      <bpmn:documentation>El proceso inicia cuando un empleado requiere recuperar el dinero correspondiente a un gasto realizado por su actividad laboral.</bpmn:documentation>
      <bpmn:outgoing>Flow_0zz28gx</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="CompuertaMontoDentroLimite" name="¿Monto dentro del límite?">
      <bpmn:documentation>Determina si el monto del gasto está dentro del límite establecido para la categoría.</bpmn:documentation>
      <bpmn:incoming>Flow_0a5r2fi</bpmn:incoming>
      <bpmn:outgoing>Flow_15cdwlw</bpmn:outgoing>
      <bpmn:outgoing>Flow_0i3e34x</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="CompuertaCategoriaValida" name="¿Categoría válida?">
      <bpmn:documentation>Determina si la categoría del gasto puede ser procesada.</bpmn:documentation>
      <bpmn:incoming>Flow_0tos3lk</bpmn:incoming>
      <bpmn:outgoing>Flow_1yxg7ek</bpmn:outgoing>
      <bpmn:outgoing>Flow_12aga9n</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="CompuertaDatosCompletos" name="¿Datos completos?">
      <bpmn:documentation>Evalúa si la rendición contiene todos los datos requeridos para continuar el proceso.</bpmn:documentation>
      <bpmn:incoming>Flow_1hnhcbm</bpmn:incoming>
      <bpmn:outgoing>Flow_11cdt0y</bpmn:outgoing>
      <bpmn:outgoing>Flow_0x0xgdp</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="CompuertaEmpleadoValidoActivo" name="¿Empleado válido y activo?">
      <bpmn:documentation>Determina si el empleado está habilitado para presentar una rendición.</bpmn:documentation>
      <bpmn:incoming>Flow_14irdra</bpmn:incoming>
      <bpmn:outgoing>Flow_1w5qwps</bpmn:outgoing>
      <bpmn:outgoing>Flow_1sjrvlv</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EventoFinSolicitudResuelta" name="Solicitud resuelta">
      <bpmn:documentation>El proceso finaliza cuando el empleado toma conocimiento del resultado de la rendición presentada.</bpmn:documentation>
      <bpmn:incoming>Flow_1g1jjd0</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="CompuertaLimiteJustificado" name="¿Superar el límite está justificado?">
      <bpmn:incoming>Flow_0etjjpu</bpmn:incoming>
      <bpmn:outgoing>Flow_1p4q0sz</bpmn:outgoing>
      <bpmn:outgoing>Flow_15kjq3b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0zz28gx" sourceRef="EventoInicioReintegroGastoRequerido" targetRef="TareaCompletarRendicion" />
    <bpmn:sequenceFlow id="Flow_0c38uje" sourceRef="TareaCompletarRendicion" targetRef="TareaEnviarRendicion" />
    <bpmn:sequenceFlow id="Flow_10ndbj8" sourceRef="TareaEnviarRendicion" targetRef="TareaRecibirRendicion" />
    <bpmn:sequenceFlow id="Flow_1b6z9hl" sourceRef="TareaSolicitarCorreccion" targetRef="CompuertaConvergenteNotificarResultado" />
    <bpmn:sequenceFlow id="Flow_1nv07gq" sourceRef="TareaNotificarResultado" targetRef="TareaConfirmarRecepcionDecision" />
    <bpmn:sequenceFlow id="Flow_1g1jjd0" sourceRef="TareaConfirmarRecepcionDecision" targetRef="EventoFinSolicitudResuelta" />
    <bpmn:sequenceFlow id="Flow_1yxg7ek" name="Sí" sourceRef="CompuertaCategoriaValida" targetRef="TareaVerificarLimiteAprobacion">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=categoriaValida = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0a5r2fi" sourceRef="TareaVerificarLimiteAprobacion" targetRef="CompuertaMontoDentroLimite" />
    <bpmn:sequenceFlow id="Flow_15cdwlw" name="No" sourceRef="CompuertaMontoDentroLimite" targetRef="TareaDerivarSolicitud">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=montoDentroLimite = false
</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0i3e34x" name="Sí" sourceRef="CompuertaMontoDentroLimite" targetRef="TareaAprobarSolicitud">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=montoDentroLimite = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1qrd7yh" sourceRef="TareaDerivarSolicitud" targetRef="TareaRevisarSolicitudDerivada" />
    <bpmn:sequenceFlow id="Flow_0uuez6g" sourceRef="TareaAprobarSolicitud" targetRef="CompuertaConvergenteGestionarReintegro" />
    <bpmn:sequenceFlow id="Flow_1fvo13p" sourceRef="TareaRecibirRendicion" targetRef="TareaRevisarDatosObligatorios" />
    <bpmn:sequenceFlow id="Flow_0x0xgdp" name="No" sourceRef="CompuertaDatosCompletos" targetRef="TareaSolicitarCorreccion">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=datosCompletos = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0tos3lk" sourceRef="TareaValidarCategoria" targetRef="CompuertaCategoriaValida" />
    <bpmn:sequenceFlow id="Flow_12aga9n" name="No" sourceRef="CompuertaCategoriaValida" targetRef="CompuertaConvergenteRechazoSolicitud">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=categoriaValida = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1w5qwps" name="Sí" sourceRef="CompuertaEmpleadoValidoActivo" targetRef="TareaValidarCategoria">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=empleadoValidoActivo = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1hnhcbm" sourceRef="TareaRevisarDatosObligatorios" targetRef="CompuertaDatosCompletos" />
    <bpmn:sequenceFlow id="Flow_11cdt0y" name="Sí" sourceRef="CompuertaDatosCompletos" targetRef="TareaValidarEmpleado">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=datosCompletos = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_14irdra" sourceRef="TareaValidarEmpleado" targetRef="CompuertaEmpleadoValidoActivo" />
    <bpmn:sequenceFlow id="Flow_1sjrvlv" name="No" sourceRef="CompuertaEmpleadoValidoActivo" targetRef="CompuertaConvergenteRechazoSolicitud">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=empleadoValidoActivo = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1p4q0sz" name="Sí" sourceRef="CompuertaLimiteJustificado" targetRef="TareaAutorizarExcepcionMonto">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=limiteJustificado = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0s0jkhk" sourceRef="TareaAutorizarExcepcionMonto" targetRef="TareaComunicarAutorizacionMonto" />
    <bpmn:sequenceFlow id="Flow_15kjq3b" name="No" sourceRef="CompuertaLimiteJustificado" targetRef="TareaRechazarMontoSolicitud">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=limiteJustificado = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0w9p78b" sourceRef="TareaRechazarMontoSolicitud" targetRef="TareaComunicarRechazoMonto" />
    <bpmn:sequenceFlow id="Flow_0etjjpu" sourceRef="TareaRevisarSolicitudDerivada" targetRef="CompuertaLimiteJustificado" />
    <bpmn:sequenceFlow id="Flow_14prhcz" sourceRef="TareaComunicarAutorizacionMonto" targetRef="TareaConfirmarRecepcionAutorizacionMonto" />
    <bpmn:sequenceFlow id="Flow_0i6plhz" sourceRef="TareaComunicarRechazoMonto" targetRef="TareaConfirmarRecepcionRechazoMonto" />
    <bpmn:manualTask id="TareaCompletarRendicion" name="Completar rendición">
      <bpmn:documentation>El empleado completa la información necesaria para solicitar el reintegro: legajo, categoría, monto, descripción y comprobante si corresponde.</bpmn:documentation>
      <bpmn:incoming>Flow_0zz28gx</bpmn:incoming>
      <bpmn:outgoing>Flow_0c38uje</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaEnviarRendicion" name="Enviar rendición">
      <bpmn:documentation>El empleado envía la rendición al área administrativa mediante correo electrónico, planilla u otro canal manual.</bpmn:documentation>
      <bpmn:incoming>Flow_0c38uje</bpmn:incoming>
      <bpmn:outgoing>Flow_10ndbj8</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaRecibirRendicion" name="Recibir rendición">
      <bpmn:documentation>El área administrativa recibe la rendición enviada por el empleado.</bpmn:documentation>
      <bpmn:incoming>Flow_10ndbj8</bpmn:incoming>
      <bpmn:outgoing>Flow_1fvo13p</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaSolicitarCorreccion" name="Solicitar corrección">
      <bpmn:documentation>El área administrativa solicita al empleado que corrija o complete la información faltante.</bpmn:documentation>
      <bpmn:incoming>Flow_0x0xgdp</bpmn:incoming>
      <bpmn:outgoing>Flow_1b6z9hl</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaRevisarDatosObligatorios" name="Revisar datos obligatorios">
      <bpmn:documentation>El área administrativa revisa si la rendición contiene la información mínima necesaria para ser procesada.</bpmn:documentation>
      <bpmn:incoming>Flow_1fvo13p</bpmn:incoming>
      <bpmn:outgoing>Flow_1hnhcbm</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaValidarEmpleado" name="Validar empleado">
      <bpmn:documentation>El área administrativa verifica si el legajo informado existe y si el empleado se encuentra activo.</bpmn:documentation>
      <bpmn:incoming>Flow_11cdt0y</bpmn:incoming>
      <bpmn:outgoing>Flow_14irdra</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaValidarCategoria" name="Validar categoría">
      <bpmn:documentation>El área administrativa verifica si la categoría informada corresponde a una categoría permitida por la política interna.</bpmn:documentation>
      <bpmn:incoming>Flow_1w5qwps</bpmn:incoming>
      <bpmn:outgoing>Flow_0tos3lk</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaVerificarLimiteAprobacion" name="Verificar límite de aprobación">
      <bpmn:documentation>El área administrativa compara el monto informado con el límite permitido para determinar si la rendición puede aprobarse directamente o debe derivarse al supervisor.</bpmn:documentation>
      <bpmn:incoming>Flow_1yxg7ek</bpmn:incoming>
      <bpmn:outgoing>Flow_0a5r2fi</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaAprobarSolicitud" name="Aprobar solicitud">
      <bpmn:documentation>El área administrativa aprueba la rendición porque cumple con las condiciones internas.</bpmn:documentation>
      <bpmn:incoming>Flow_0i3e34x</bpmn:incoming>
      <bpmn:outgoing>Flow_0uuez6g</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaDerivarSolicitud" name="Derivar solicitud">
      <bpmn:documentation>El área administrativa deriva la solicitud al supervisor porque el monto supera el límite de aprobación directa.</bpmn:documentation>
      <bpmn:incoming>Flow_15cdwlw</bpmn:incoming>
      <bpmn:outgoing>Flow_1qrd7yh</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaConfirmarRecepcionAutorizacionMonto" name="Confirmar recepción autorización del monto">
      <bpmn:documentation>El área administrativa toma conocimiento de la autorización del monto de la solicitud derivada por parte del supervisor.</bpmn:documentation>
      <bpmn:incoming>Flow_14prhcz</bpmn:incoming>
      <bpmn:outgoing>Flow_0u83gdv</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaConfirmarRecepcionDecision" name="Confirmar recepción de la decisión">
      <bpmn:documentation>El empleado toma conocimiento de la decisión comunicada por el área administrativa sobre la rendición presentada.</bpmn:documentation>
      <bpmn:incoming>Flow_1nv07gq</bpmn:incoming>
      <bpmn:outgoing>Flow_1g1jjd0</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaRevisarSolicitudDerivada" name="Revisar solicitud derivada">
      <bpmn:documentation>El supervisor revisa el caso escalado desde área administrativa</bpmn:documentation>
      <bpmn:incoming>Flow_1qrd7yh</bpmn:incoming>
      <bpmn:outgoing>Flow_0etjjpu</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaAutorizarExcepcionMonto" name="Autorizar excepción del monto">
      <bpmn:documentation>El supervisor autoriza el monto excepcional de la solicitud porque la superación del límite está justificada.</bpmn:documentation>
      <bpmn:incoming>Flow_1p4q0sz</bpmn:incoming>
      <bpmn:outgoing>Flow_0s0jkhk</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaRechazarMontoSolicitud" name="Rechazar excepción del monto">
      <bpmn:documentation>El supervisor rechaza el monto excepcional de la solicitud porque la superación del límite no está justificada.</bpmn:documentation>
      <bpmn:incoming>Flow_15kjq3b</bpmn:incoming>
      <bpmn:outgoing>Flow_0w9p78b</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaComunicarAutorizacionMonto" name="Comunicar autorización del monto">
      <bpmn:documentation>El supervisor comunica al área administrativa que el monto de la solicitud fue autorizado ya que la superación del límite está justificada.</bpmn:documentation>
      <bpmn:incoming>Flow_0s0jkhk</bpmn:incoming>
      <bpmn:outgoing>Flow_14prhcz</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaComunicarRechazoMonto" name="Comunicar rechazo del monto">
      <bpmn:documentation>El supervisor comunica al área administrativa que el monto de la solicitud fue rechazado ya que la superación del límite no está justificada.</bpmn:documentation>
      <bpmn:incoming>Flow_0w9p78b</bpmn:incoming>
      <bpmn:outgoing>Flow_0i6plhz</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaRechazarSolicitud" name="Rechazar solicitud">
      <bpmn:documentation>El área administrativa rechaza la rendición porque no cumple las condiciones requeridas para continuar el proceso.</bpmn:documentation>
      <bpmn:incoming>Flow_1inyc7f</bpmn:incoming>
      <bpmn:outgoing>Flow_0gk7xr3</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:sequenceFlow id="Flow_0gk7xr3" sourceRef="TareaRechazarSolicitud" targetRef="CompuertaConvergenteRegistrarResultado" />
    <bpmn:sequenceFlow id="Flow_1inyc7f" sourceRef="CompuertaConvergenteRechazoSolicitud" targetRef="TareaRechazarSolicitud" />
    <bpmn:manualTask id="TareaNotificarResultado" name="Notificar resultado">
      <bpmn:documentation>El área administrativa comunica al empleado el resultado final de la rendición.</bpmn:documentation>
      <bpmn:incoming>Flow_1rvupq9</bpmn:incoming>
      <bpmn:outgoing>Flow_1nv07gq</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaRegistrarResultado" name="Registrar resultado">
      <bpmn:documentation>El área administrativa registra el resultado final de la rendición en la planilla o registro correspondiente.</bpmn:documentation>
      <bpmn:incoming>Flow_17weotc</bpmn:incoming>
      <bpmn:outgoing>Flow_051o44d</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="TareaConfirmarRecepcionRechazoMonto" name="Confirmar recepción rechazo del monto">
      <bpmn:documentation>El área administrativa toma conocimiento del rechazo del monto de la solicitud derivada por parte del supervisor.</bpmn:documentation>
      <bpmn:incoming>Flow_0i6plhz</bpmn:incoming>
      <bpmn:outgoing>Flow_1ma5fws</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="CompuertaConvergenteRegistrarResultado">
      <bpmn:documentation>Unifica los caminos excluyentes que deben registrarse como resultado de la rendición antes de continuar con la notificación al empleado.</bpmn:documentation>
      <bpmn:incoming>Flow_1ma5fws</bpmn:incoming>
      <bpmn:incoming>Flow_05eo6oq</bpmn:incoming>
      <bpmn:incoming>Flow_0gk7xr3</bpmn:incoming>
      <bpmn:outgoing>Flow_17weotc</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="TareaGestionarReintegro" name="Gestionar reintegro">
